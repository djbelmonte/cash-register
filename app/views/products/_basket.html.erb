<div id="basket" class="w-full max-w-xl rounded-lg bg-white shadow-lg p-6 mt-4">
  <ul class="space-y-2">
    <% basket.basket_items.includes(:product).each do |item| %>
      <li class="flex items-center justify-between border-b border-gray-100 pb-2 last:border-b-0 last:pb-0">
        <div class="flex-grow flex items-baseline justify-between pr-4">
            <span class="text-lg text-gray-800"><%= item.product.name %></span>
            <span class="text-xl font-bold text-gray-700"><%= number_to_currency(item.promotional_price, unit: "€") %></span>
        </div>
        <div class="w-24 flex-shrink-0 text-right">
          <%= button_to "Remove", basket_basket_item_path(item),
                        method: :delete,
                        class: "w-full rounded-md bg-red-500 px-3 py-1 text-white shadow-sm hover:bg-red-600 focus:outline-none focus:ring-2 focus:ring-red-400 focus:ring-opacity-75 text-sm" %>
        </div>
      </li>
    <% end %>
  </ul>

  <h3 class="mt-6 pt-4 border-t border-gray-300 text-right text-3xl font-bold text-gray-800">
    Total: <span class="text-green-700"><%= number_to_currency(basket_total, unit: "€") %></span>
  </h3>
</div>