<h1>Cash Register</h1>

<h2>Products</h2>
<ul>
  <% @products.each do |product| %>
    <li>
      <%= product.name %>
      <%= number_to_currency(product.price, unit: "€") %>
      <%= button_to "Add to Basket",
                    basket_basket_items_path(product_id: product.id),
                    method: :post %>
    </li>
  <% end %>
</ul>

<h2>Your Basket</h2>
<ul>
  <% @basket.basket_items.includes(:product).each do |item| %>
    <li>
      <%= item.product.name %>
      <%= number_to_currency(item.product.price, unit: "€") %>
      <%= button_to "Remove", basket_basket_item_path(item),
                    method: :delete,
                    data: { turbo_confirm: "Remove this item?" } %>
    </li>
  <% end %>
</ul>

<h3>Total: <%= number_to_currency(@basket_total, unit: "€") %></h3>
